# Runtime directories
data/*
inbox/*
outbox/*
processing/*
failed/*
logs/*
models/*

# Keep folder structure
!data/.gitkeep
!data/portfolio/
!data/portfolio/.gitkeep
!data/derived/
!data/derived/.gitkeep

# Derived outputs (aggregates only, never commit)
data/derived/*.json
!inbox/.gitkeep
!outbox/.gitkeep
!processing/.gitkeep
!failed/.gitkeep
!logs/.gitkeep
!models/.gitkeep

# Secrets
.env
env/
*.key
*.pem

# Financial files
*.csv
data/portfolio/accounts.yaml

# ORI Personal — personal investor profile and answers, never commit
data/portfolio/profile.yaml
data/portfolio/answers.yaml

# Logs
*.log
*.jsonl

# Python
__pycache__/
*.pyc

# IDE
.vscode/

# Local dashboard overrides (never commit)
dashboard.yaml

# LLM provider config — may contain model names and provider choices
# API keys must never be stored here; read from env vars only
llm_config.yaml
